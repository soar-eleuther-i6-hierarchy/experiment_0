# Large tensor caches stay in git-LFS (~3.4 GB) — never served by Pages.
outputs/**/*.pt filter=lfs diff=lfs merge=lfs -text
outputs/*.pt filter=lfs diff=lfs merge=lfs -text

# HTML dashboards are deliberately NOT in LFS: GitHub Pages does not resolve
# LFS objects and would serve the pointer stub instead of the page.
outputs/**/*.html -filter -diff -merge text
outputs/*.html -filter -diff -merge text
